{
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "service": "tsx apps/service/src/index.ts",
    "console": "vite apps/console --host 127.0.0.1 --port 5173",
    "build:service": "tsc -p tsconfig.service-build.json",
    "build:console": "node scripts/build-console.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "desktop": "npm run build:console && electron apps/desktop/main.cjs",
    "desktop:dev": "npm run build:console && electron apps/desktop/main.cjs",
    "build:desktop": "npm run build:console && npm run build:service && node scripts/build-desktop.mjs",
    "package:desktop": "npm run build:desktop && node scripts/package-desktop-portable.mjs",
    "shortcut:desktop": "node scripts/create-desktop-shortcut.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "electron": "^42.4.1",
    "jsdom": "^25.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
